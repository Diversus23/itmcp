# Конфигурация MCP-прокси сервера

# Настройки подключения к 1С (обязательные при AUTH_MODE=none)
MCP_ONEC_URL=http://localhost/your_base_name
MCP_ONEC_USERNAME=your_username
MCP_ONEC_PASSWORD=your_password

# Настройки HTTP-сервиса 1С (опциональные)
MCP_ONEC_SERVICE_ROOT=mcp
# Таймаут запросов к 1С в миллисекундах (по умолчанию 120000 = 2 минуты)
# MCP_ONEC_TIMEOUT=120000

# Настройки HTTP-сервера (опциональные)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Настройки MCP-сервера (опциональные)
MCP_SERVER_NAME=IT-MCP
MCP_SERVER_VERSION=1.0.0

# Настройки логирования (опциональные)
MCP_LOG_LEVEL=INFO

# Настройки CORS (опциональные)
# MCP_CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# Настройки авторизации OAuth2 (опциональные)
# Режим авторизации: none (по умолчанию) или oauth2
MCP_AUTH_MODE=none

# При AUTH_MODE=oauth2 значения MCP_ONEC_USERNAME/MCP_ONEC_PASSWORD игнорируются

# Публичный URL прокси для OAuth2 (обязательно при AUTH_MODE=oauth2)
# MCP_PUBLIC_URL=https://your-mcp-proxy.example.com

# TTL (время жизни) для OAuth2 токенов в секундах (опциональные)
MCP_OAUTH2_CODE_TTL=120
MCP_OAUTH2_ACCESS_TTL=3600
MCP_OAUTH2_REFRESH_TTL=1209600

# Путь к файлу-снапшоту OAuth2 токенов. Если задан — токены переживут
# перезапуск процесса (docker compose restart, краш). Если не задан —
# хранятся только в памяти и теряются при рестарте.
MCP_OAUTH2_STORE_PATH=./data/oauth2.json

# Окно идемпотентности при ротации refresh-токена (мс).
# Повторное использование одного refresh_token в этом окне возвращает
# ранее выпущенные токены (защита от race condition при параллельных
# refresh-запросах). По истечении окна — отзыв всей цепочки.
MCP_OAUTH2_REFRESH_GRACE_MS=60000
