# Конфигурация MCP-прокси для Docker
#
# Скопируйте этот файл в .env и отредактируйте:
#   cp .env.docker.example .env

# Настройки подключения к 1С (обязательные)
# Если 1С на том же хосте (Windows/Mac): http://host.docker.internal:порт/база
# Если 1С на другом сервере: http://адрес:порт/база
# Если 1С в Docker (та же сеть): http://имя-сервиса:порт/база
MCP_ONEC_URL=http://host.docker.internal:8080/it4
MCP_ONEC_USERNAME=Администратор
MCP_ONEC_PASSWORD=

# Настройки HTTP-сервера (не меняйте для Docker)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Настройки MCP-сервера (опциональные)
MCP_SERVER_NAME=IT-MCP
MCP_SERVER_VERSION=1.0.0

# Настройки логирования
MCP_LOG_LEVEL=INFO

# Режим авторизации: none или oauth2
MCP_AUTH_MODE=none

# --- Настройки OAuth2 (используются при MCP_AUTH_MODE=oauth2) ---

# Публичный URL прокси (обязательно при oauth2)
# MCP_PUBLIC_URL=https://your-mcp-proxy.example.com

# TTL токенов (сек)
MCP_OAUTH2_CODE_TTL=120
MCP_OAUTH2_ACCESS_TTL=3600
MCP_OAUTH2_REFRESH_TTL=1209600

# Снапшот токенов на диске (переживает рестарт контейнера).
# Путь ВНУТРИ контейнера — каталог /app/data примонтирован как volume
# (см. docker-compose.yml). На хосте файл лежит в ./data/oauth2.json.
MCP_OAUTH2_STORE_PATH=/app/data/oauth2.json

# Окно идемпотентности при ротации refresh-токена (мс).
MCP_OAUTH2_REFRESH_GRACE_MS=60000
